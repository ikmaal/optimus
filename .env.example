# SQLite (Prisma resolves relative URLs from the prisma/ folder → prisma/dev.db)
DATABASE_URL="file:./dev.db"

# Slack daily digest — pick ONE approach:
# A) Incoming Webhook or Workflow trigger URL (paste from Slack)
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
#    or Workflow: https://hooks.slack.com/triggers/...
# If using Workflow triggers: add a Text field in the webhook step named e.g. "Digest" (JSON key often `digest`)
# and set the same key here if Slack shows something different:
# SLACK_WORKFLOW_MESSAGE_KEY="digest"

# B) Bot API (alternative)
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_CHANNEL_ID="C01234567"

# Optional: for `npm run digest:trigger` against a deployed app (default: http://localhost:3000)
# DIGEST_BASE_URL="https://cars.example.com"

# Protect GET /api/cron/daily-digest (Authorization: Bearer <this value>)
# CRON_SECRET="generate-a-long-random-string"
